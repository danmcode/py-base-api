# ============================================================
# Variables de entorno — PRODUCCIÓN
# Copia a .env.prod y rellena con valores reales y seguros
# NUNCA subas .env.prod al repositorio
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=fastapi_prod
POSTGRES_USER=fastapi_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
POSTGRES_DB_HOST=db
POSTGRES_DB_PORT=5432

# --- SQLAlchemy ---
DATABASE_URL=postgresql://fastapi_user:CHANGE_ME_STRONG_PASSWORD@db:5432/fastapi_prod

# --- JWT ---
SECRET_KEY=CHANGE_ME_STRONG_SECRET_KEY_MIN_32_CHARS
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- App ---
ENVIRONMENT=production
DEBUG=false

# --- CORS ---
CORS_ORIGINS=["https://test.prod"]

# --- Nginx (solo referencia, el compose lo inyecta directamente) ---
NGINX_DOMAIN=test.prod
