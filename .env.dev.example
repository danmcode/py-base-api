# ============================================================
# Variables de entorno — DESARROLLO
# Copia este archivo a .env.dev y ajusta los valores
# NUNCA subas .env.dev al repositorio
# ============================================================

# --- PostgreSQL (usadas por el contenedor postgres y por FastAPI) ---
POSTGRES_DB=fastapi_dev
POSTGRES_USER=fastapi_user
POSTGRES_PASSWORD=change_me_dev_password
POSTGRES_DB_HOST=db
POSTGRES_DB_PORT=5432

# --- SQLAlchemy ---
DATABASE_URL=postgresql+asyncpg://fastapi_user:change_me_dev_password@db:5432/fastapi_dev

# --- JWT ---
SECRET_KEY=change_me_dev_secret_key_use_a_long_random_string
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- CORS ---
CORS_ORIGINS=["http://localhost:5173","https://test.dev"]

# --- Nginx (solo referencia, el compose lo inyecta directamente) ---
NGINX_DOMAIN=test.dev
